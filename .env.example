# ---------------------------------------------------------------------------
# Contoh environment untuk docker-compose.yml (build & run lokal Dokploy).
# Salin file ini menjadi `.env` dan sesuaikan nilainya bila perlu.
# ---------------------------------------------------------------------------

# Alamat publik / IP host Dokploy (untuk Swarm advertise address)
ADVERTISE_ADDR=127.0.0.1

# PostgreSQL
POSTGRES_USER=dokploy
POSTGRES_DB=dokploy
POSTGRES_PASSWORD=amukds4wi9001583845717ad2

# Better Auth — WAJIB diganti dengan string acak yang panjang (>= 32 karakter)
# Contoh generate: openssl rand -hex 32
BETTER_AUTH_SECRET=please-change-me-to-a-long-random-string

# Enterprise (lokal): bypass gate license — 1 = aktif (default compose), 0 = mati (uji alur license asli)
# Dengan NODE_ENV=development (pnpm dev) bypass otomatis aktif kecuali Anda set =0.
DOKPLOY_ENTERPRISE_LOCAL_BYPASS=1

# Traefik (port di host)
TRAEFIK_PORT=80
TRAEFIK_SSL_PORT=443
TRAEFIK_HTTP3_PORT=443
TRAEFIK_VERSION=3.6.7
